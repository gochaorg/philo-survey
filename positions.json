{
  "nodes": [
    { "id": "materialism", "section": "ontology", "label": "Материализм", "desc": "Мир состоит только из физической материи." },
    { "id": "idealism", "section": "ontology", "label": "Идеализм", "desc": "Первооснова мира — дух, идеи, сознание или симуляция." },
    { "id": "nominalism", "section": "ontology", "label": "Номинализм", "desc": "Абстрактные понятия (красота, числа) — лишь имена, созданные человеком." },
    { "id": "platonism", "section": "ontology", "label": "Платонизм / Реализм", "desc": "Идеи, математика и универсалии существуют объективно." },
    
    { "id": "empirism", "section": "epistemology", "label": "Эмпиризм", "desc": "Единственный источник знаний — чувственный опыт и эксперимент." },
    { "id": "rationalism", "section": "epistemology", "label": "Рационализм", "desc": "Истину можно познать чистым разумом и логикой без опыта." },
    { "id": "skepticism", "section": "epistemology", "label": "Скептицизм / Агностицизм", "desc": "Мир принципиально непознаваем, истина недостижима." },
    { "id": "scientism", "section": "epistemology", "label": "Сайентизм", "desc": "Наука — единственный легитимный и высший способ познания." },
    
    { "id": "correspondence_truth", "section": "truth", "label": "Корреспондентская истина", "desc": "Истина — это то, что строго соответствует фактам реальности." },
    { "id": "pragmatic_truth", "section": "truth", "label": "Прагматическая истина", "desc": "Истинно то, что полезно и эффективно работает на практике." },
    { "id": "relativism_truth", "section": "truth", "label": "Релятивизм истины", "desc": "Объективной истины нет, у каждого своя правда и контекст." },
    
    { "id": "classical_logic", "section": "logic", "label": "Классическая логика", "desc": "Законы логики абсолютны, объективны и неизменны." },
    { "id": "logic_constructivism", "section": "logic", "label": "Конструктивизм / Постмодерн", "desc": "Логика — лишь изобретенный человеком инструмент или языковая игра." },
    
    { "id": "physicalism", "section": "mind", "label": "Физикализм / Редукционизм", "desc": "Сознание — это просто электрохимия мозга." },
    { "id": "dualism_mind", "section": "mind", "label": "Дуализм сознания", "desc": "Сознание имеет нематериальную природу, отличную от тела." },
    { "id": "functionalism", "section": "mind", "label": "Функционализм (ИИ)", "desc": "ИИ может обладать полноценным сознанием, если копирует его функции." },
    { "id": "panpsychism", "section": "mind", "label": "Панпсихизм", "desc": "Элементарные частицы обладают базовым свойством чувствовать." },
    
    { "id": "hard_determinism", "section": "determinism", "label": "Жесткий детерминизм", "desc": "Все события предопределены законами физики, свободы воли нет." },
    { "id": "libertarianism_will", "section": "determinism", "label": "Либертарианство воли", "desc": "Человек обладает абсолютной свободой воли, выбор не предопределен." },
    { "id": "compatibilism", "section": "determinism", "label": "Компатибилизм", "desc": "Свобода воли совместима с детерминизмом (мы свободны, пока действуем без принуждения)." },
    
    { "id": "utilitarianism", "section": "ethics", "label": "Утилитаризм", "desc": "Морально то, что приносит максимум пользы большинству." },
    { "id": "deontology", "section": "ethics", "label": "Деонтология", "desc": "Мораль — это выполнение абсолютного долга и правил (Кант)." },
    
    { "id": "value_objectivism", "section": "values", "label": "Объективизм ценностей", "desc": "Добро и зло объективны и существуют независимо от людей." },
    { "id": "nihilism", "section": "values", "label": "Нигилизм / Субъективизм", "desc": "Ценности выдуманы людьми, объективного смысла и морали нет." },
    
    { "id": "individualism", "section": "social", "label": "Индивидуализм / Либертарианство", "desc": "Права и свобода отдельной личности превыше интересов общества." },
    { "id": "collectivism", "section": "social", "label": "Коллективизм / Коммунитаризм", "desc": "Интересы и благо общества важнее эгоистичных прав индивида." },
    { "id": "epistocracy", "section": "social", "label": "Эпистократия / Технократия", "desc": "Управлять государством должны только компетентные эксперты и ученые." },
    { "id": "democratism", "section": "social", "label": "Демократизм", "desc": "Все граждане имеют равное право влиять на власть, независимо от знаний." },

    { "id": "constructivism_values", "section": "values", "label": "Конструктивизм / Гуманизм", "desc": "Ценности создаются людьми, но от этого они не фикция, а основа общества." },
    { "id": "virtue_ethics", "section": "ethics", "label": "Этика добродетели", "desc": "Мораль в развитии личных качеств и характера, а не в следовании правилам или расчете пользы." },
    { "id": "coherence_truth", "section": "truth", "label": "Когерентная истина", "desc": "Истина — это логическая согласованность высказывания с общей системой знаний." },
    { "id": "psychologism_logic", "section": "logic", "label": "Психологизм", "desc": "Законы логики — продукт когнитивных процессов мозга, а не абсолютные правила вселенной." },


    {
      "id": "aesthetic_objectivism",
      "section": "aesthetics",
      "label": "Формальный объективизм",
      "desc": "Красота — объективное свойство формы: симметрия, пропорции, золотое сечение существуют независимо от зрителя."
    },
    {
      "id": "aesthetic_hedonism",
      "section": "aesthetics",
      "label": "Гедонистический субъективизм",
      "desc": "Эстетическая ценность равна силе чувственного удовольствия. «Красиво» значит «мне приятно»."
    },
    {
      "id": "aesthetic_emotivism",
      "section": "aesthetics",
      "label": "Эмотивизм / Вчувствование",
      "desc": "Красота — это проекция моих эмоций на объект; эстетический опыт — резонанс чувств."
    },
    {
      "id": "aesthetic_constructivism",
      "section": "aesthetics",
      "label": "Институциональный конструктивизм",
      "desc": "Что считать искусством и прекрасным, определяет «мир искусства» — галереи, критика, исторический контекст."
    },
    {
      "id": "semiotic_aesthetics",
      "section": "aesthetics",
      "label": "Семиотическая эстетика",
      "desc": "Произведение — знаковая система. Красота — в глубине интерпретации, в диалоге культурных кодов и смыслов."
    },

    {
      "id": "linguistic_universalism",
      "section": "language",
      "label": "Лингвистический универсализм",
      "desc": "В основе всех языков лежат врождённые логические структуры; язык лишь одежда для мысли."
    },
    {
      "id": "linguistic_relativism",
      "section": "language",
      "label": "Лингвистический релятивизм",
      "desc": "Язык формирует мышление: разные языки создают несоизмеримые картины мира."
    },
    {
      "id": "linguistic_structuralism",
      "section": "language",
      "label": "Структурализм / Постструктурализм",
      "desc": "Язык — самодостаточная система знаков; значения рождаются из различий, а не из связи с реальностью."
    },

    {
      "id": "personalist_truth",
      "section": "religion",
      "label": "Персоналистская истина",
      "desc": "Истина — не безличный факт, а живая Личность, с которой можно вступить в отношение (напр. Христос)."
    },
    {
      "id": "fideism",
      "section": "religion",
      "label": "Фидеизм",
      "desc": "Божественная истина даётся исключительно через веру и откровение; разум здесь бессилен."
    },
    {
      "id": "theological_rationalism",
      "section": "religion",
      "label": "Теологический рационализм",
      "desc": "Вера и разум гармоничны; бытие Бога и основные истины можно частично обосновать рационально."
    },
    {
      "id": "religious_experientialism",
      "section": "religion",
      "label": "Религиозный эмпиризм",
      "desc": "Основа веры — личный духовный опыт, мистическое переживание встречи с Божественным."
    },
    {
      "id": "personalist_faith",
      "section": "religion",
      "label": "Вера как отношение",
      "desc": "Религия — прежде всего личные отношения, диалог и доверие между человеком и Богом-личностью."
    },
    {
      "id": "worldview_faith",
      "section": "religion",
      "label": "Вера как мировоззрение",
      "desc": "Религия — система взглядов, практик и этических принципов; вера может быть не-теистической (буддизм, даосизм)."
    }
  ],
